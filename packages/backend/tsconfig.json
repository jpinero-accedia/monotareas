{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "ES2023",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2023"],
		"outDir": "dist",
		"rootDir": "src",
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"declarationDir": "dist/types",
		"sourceMap": true
	},
	"include": ["src/**/*"]
}
